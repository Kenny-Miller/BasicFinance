{
  "name": "basic-finance.client",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "run-script-os",
    "start:win32": "ng serve --port %PORT%",
    "start:default": "ng serve --port $PORT",
    "start-standalone": "ng serve --port 4200",
    "build": "ng build",
    "postbuild": "npx tsx scripts/generate-environment-config.ts",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --coverage",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular-eslint/template-parser": "^20.6.0",
    "@angular/cdk": "^21.0.2",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@googleworkspace/drive-picker-element": "^0.7.3",
    "@ng-icons/core": ">=32.0.0 <34.0.0",
    "@ng-icons/lucide": ">=32.0.0 <34.0.0",
    "@spartan-ng/brain": "^1.1.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/google.picker": "^0.0.52",
    "angular-oauth2-oidc": "^20.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "echarts": "^6.1.0",
    "ng2-charts": "^8.0.0",
    "ngx-echarts": "^21.0.0",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.17",
    "tslib": "^2.3.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@angular/build": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.0.3",
    "@spartan-ng/cli": "^1.1.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jasmine": "~5.1.0",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "angular-eslint": "20.6.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "run-script-os": "^1.1.6",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.3",
    "vitest": "^4.1.10"
  }
}
