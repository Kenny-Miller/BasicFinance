{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "endOfLine": "lf",
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "tailwindFunctions": ["hlm", "cva"],
  "tailwindStylesheet": "./src/styles.css",
  "plugins": ["prettier-plugin-tailwindcss", "@trivago/prettier-plugin-sort-imports"],
  "overrides": [
    {
      "files": "*.html",
      "options": { "parser": "angular" }
    }
  ],
  "importOrder": [
    "^@angular/(.*)$",
    "^rxjs(.*)$",
    "^@ngrx/(.*)$",
    "<THIRD_PARTY_MODULES>",
    "^@env/(.*)$",
    "^@core/(.*)$",
    "^@shared/(.*)$",
    "^@features/(.*)$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
